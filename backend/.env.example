# ── HORNAX API — variables d'environnement ───────────────────

# Port d'écoute (Render fournit PORT automatiquement)
PORT=3001

# Secret de signature des JWT (mets une longue chaîne aléatoire en prod)
JWT_SECRET=remplace-par-une-chaine-aleatoire-longue

# Clé API Riot (optionnelle — pour l'import de matchs / scouting)
RIOT_API_KEY=RGAPI-REMPLACE-MOI

# ── Base de données ──────────────────────────────────────────
# En LOCAL : laisse ces deux lignes vides/absentes → fichier data/hornax.db
# En PROD (Turso) : renseigne les deux (récupérés via la CLI Turso)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Mot de passe par défaut utilisé par le seeder si un compte n'en précise pas
SEED_PASSWORD=hornax2026
